# HydroAgent 环境变量配置
# 复制为 .env 并填写实际值:  cp .env.example .env
# .env 已在 .gitignore 中，不会被提交到版本库

# ============================================================================
# LLM API（必填）
# 支持任何 OpenAI 兼容接口：Qwen / DeepSeek / OpenAI / 本地 Ollama 等
# ============================================================================

LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=deepseek-v3.1

# 可选 LLM 参数（不设置则使用默认值）
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=20000
# LLM_TIMEOUT=120
# LLM_MAX_RETRIES=1

# 常用端点（取消注释即可切换）：
# LLM_BASE_URL=https://api.deepseek.com/v1              # DeepSeek
# LLM_BASE_URL=https://api.openai.com/v1                # OpenAI
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  # Qwen (阿里云)

# ============================================================================
# 数据路径（必填）
# ============================================================================

# 数据集父目录（AquaFetch 会在此目录下找 CAMELS_US/ 等子文件夹）
# 例：数据在 D:\data\CAMELS_US\ 则填 D:\data
DATASET_DIR=D:\your\path\to\data

# 率定结果输出目录
RESULT_DIR=D:\your\path\to\results

# 项目根目录（可选，留空则自动推断）
# PROJECT_DIR=

# hydrodataset NetCDF 缓存目录（可选，留空则默认为 DATASET_DIR 下的 cache）
# CACHE_DIR=

# 自制数据集路径（可选）
# SELFMADE_DATA_PATH=
# SELFMADE_DATASET_NAME=

# ============================================================================
# Agent 参数（可选）
# ============================================================================

# Agentic Loop 最大轮次
# HYDROAGENT_MAX_TURNS=30
